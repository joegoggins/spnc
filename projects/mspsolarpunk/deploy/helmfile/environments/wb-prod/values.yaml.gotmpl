# wb-prod = the mspsolarpunk.com box (kube-context "hope-island") — its own
# physical cluster, separate from gaia/wb-staging.
cloudflared:
  ingress:
    - hostname: mspsolarpunk.com
      service: http://web.{{ .Environment.Name }}.svc.cluster.local:80

# First pass: track main like wb-staging (no promotion gate yet).
image:
  web:
    tag: deploy-main
